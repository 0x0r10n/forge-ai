{
  "name": "forge-ai",
  "version": "1.0.0",
  "description": "Forge is a powerful open-source multi-agent coding agent for the terminal. Built for speed, cost-efficiency, and full control using DeepSeek models.",
  "type": "module",
  "bin": {
    "forge": "./dist/forge.js"
  },
  "files": [
    "dist/forge.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outfile dist/forge.js --target node --external react-devtools-core && node scripts/prepend-shebang.mjs && chmod +x dist/forge.js",
    "prepublishOnly": "bun run build && bun run typecheck",
    "postinstall": "node -e \"const fs=require('fs');const d='node_modules/react-devtools-core';if(!fs.existsSync(d)){try{fs.mkdirSync(d,{recursive:true});fs.writeFileSync(d+'/package.json',JSON.stringify({name:'react-devtools-core',version:'0.0.0',main:'index.js'}));fs.writeFileSync(d+'/index.js','module.exports={};');}catch(e){}}\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "forge",
    "forge-ai",
    "ai",
    "coding-agent",
    "terminal",
    "cli",
    "deepseek",
    "llm",
    "multi-agent",
    "rag",
    "developer-tools",
    "typescript",
    "bun"
  ],
  "author": "Forge AI Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-ai/forge.git"
  },
  "homepage": "https://github.com/forge-ai/forge#readme",
  "bugs": {
    "url": "https://github.com/forge-ai/forge/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "glob": "^11.0.0",
    "ink": "^5.1.0",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "openai": "^4.67.3",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.11",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
